# Optional security/infra integrations. The app works without these (rate
# limiting falls back to in-memory; CAPTCHA verification is skipped) — set them
# in production to enable distributed rate limiting and bot protection.

# Upstash Redis (https://upstash.com) — shared rate-limit store across instances.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile (https://dash.cloudflare.com -> Turnstile) — CAPTCHA.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
