# Optional security/infra integrations. The app works without these.
#
# Rate limiting uses the app's own MongoDB by default (no setup needed).
# Upstash Redis is an OPTIONAL override — it is also used by the Edge
# middleware (global /api + login limits), which cannot reach MongoDB and
# otherwise falls back to per-instance in-memory limits.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile (https://dash.cloudflare.com -> Turnstile) — CAPTCHA.
# When unset, the widget is hidden and verification is skipped.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
